# Copy this file to .env in the workspace root, then fill in your values.
#
# Easiest safe setup (one command):
#   setup_supabase.bat
# Preview migrations first (no changes):
#   migrate_supabase_dry_run.bat
#
# What it does:
#   - Syncs Supabase keys to inventory_system/.env (frontend)
#   - Applies ONLY new SQL files to your Supabase database (skips already-applied)
#   - Does NOT install software or change your app code

# --- Supabase (Project Settings > API) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Supabase Postgres (Project Settings > Database > Connection string > URI) ---
# Use the "Session pooler" or "Direct" connection string (not the Supabase REST URL).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# --- Flask backend ---
FLASK_DEBUG=True
FLASK_RUN_PORT=5000
FRONTEND_BASE_URL=http://localhost:5174

# --- Scan APIs (backend only) ---
FNSKU_API_KEY=
RAINFOREST_API_KEY=

# --- Stripe (optional for local auth/testing) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
