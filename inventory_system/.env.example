# API URL (local or remote)
VITE_API_URL=http://localhost:5000/api

# Supabase configuration (auto-synced from root .env by scripts/setup_supabase.py)
# Or set manually from Supabase dashboard: Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Never expose SUPABASE_SERVICE_KEY in frontend .env files.

# Optional: FNSKU to ASIN API 
VITE_FNSKU_API_KEY=your-api-key-if-needed 