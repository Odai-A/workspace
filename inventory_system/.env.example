# API URL (local or remote)
VITE_API_URL=http://localhost:5000/api

# Supabase configuration
# Replace these with your actual Supabase project values from:
# Project Settings > API in your Supabase dashboard
# Frontend must use VITE_ prefixed variables.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Never expose SUPABASE_SERVICE_KEY in frontend .env files.

# Optional: FNSKU to ASIN API 
VITE_FNSKU_API_KEY=your-api-key-if-needed 